# ───────────────────────────────────────────────────────────────────────
# Supabase (obligatorio)
# ───────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ───────────────────────────────────────────────────────────────────────
# Sentry (opcional — FASE 30.10)
# Si VITE_SENTRY_DSN está vacío, el SDK no se carga ni envía eventos.
# Para activar: crear proyecto en sentry.io, pegar el DSN aquí.
# ───────────────────────────────────────────────────────────────────────
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
